<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.minimart.client.ui.LoginController"
           styleClass="login-root">

    <VBox alignment="CENTER" spacing="0">

        <!-- Logo area -->
        <VBox alignment="CENTER" spacing="8" styleClass="login-logo-area">
            <Label text="🛒" styleClass="login-logo-icon"/>
            <Label text="MINI MART" styleClass="login-brand-name"/>
            <Label text="Hệ thống Quản lý Siêu thị Mini" styleClass="login-brand-sub"/>
        </VBox>

        <!-- ════ LOGIN CARD ════ -->
        <VBox fx:id="loginCard" alignment="CENTER" spacing="16"
              styleClass="login-card" maxWidth="380">

            <Label text="Đăng nhập hệ thống" styleClass="login-title"/>

            <VBox spacing="6" maxWidth="Infinity">
                <Label text="Tên đăng nhập" styleClass="field-label"/>
                <TextField fx:id="txtUsername"
                           promptText="Nhập tên đăng nhập..."
                           styleClass="login-field"/>
            </VBox>

            <VBox spacing="6" maxWidth="Infinity">
                <Label text="Mật khẩu" styleClass="field-label"/>
                <PasswordField fx:id="txtPassword"
                               promptText="Nhập mật khẩu..."
                               styleClass="login-field"/>
            </VBox>

            <Label fx:id="lblStatus" text="" wrapText="true"
                   maxWidth="340" styleClass="status-error"/>

            <StackPane>
                <Button fx:id="btnLogin" text="ĐĂNG NHẬP"
                        onAction="#handleLogin"
                        styleClass="btn-primary" maxWidth="Infinity"/>
                <ProgressIndicator fx:id="spinner" maxWidth="28" maxHeight="28"
                                   StackPane.alignment="CENTER_RIGHT"
                                   style="-fx-progress-color: white;"/>
            </StackPane>

            <!-- Switch to register -->
            <HBox alignment="CENTER" spacing="6">
                <Label text="Chưa có tài khoản?" styleClass="login-hint"/>
                <Hyperlink fx:id="lnkGoRegister" text="Đăng ký ngay"
                           onAction="#showRegisterCard"
                           styleClass="login-link"/>
            </HBox>

            <!-- Hint -->
            <VBox alignment="CENTER" spacing="2">
                <Label text="Admin: admin / Admin@123" styleClass="login-hint"/>
                <Label text="NV: nhanvien1 / Emp@123" styleClass="login-hint"/>
            </VBox>

        </VBox>

        <!-- ════ REGISTER CARD ════ -->
        <VBox fx:id="registerCard" alignment="CENTER" spacing="16"
              styleClass="login-card" maxWidth="380"
              visible="false" managed="false">

            <Label text="Tạo tài khoản mới" styleClass="login-title"/>

            <VBox spacing="6" maxWidth="Infinity">
                <Label text="Họ và tên" styleClass="field-label"/>
                <TextField fx:id="txtRegFullName"
                           promptText="Ví dụ: Nguyễn Văn A..."
                           styleClass="login-field"/>
            </VBox>

            <VBox spacing="6" maxWidth="Infinity">
                <Label text="Tên đăng nhập" styleClass="field-label"/>
                <TextField fx:id="txtRegUsername"
                           promptText="Chọn tên đăng nhập..."
                           styleClass="login-field"/>
            </VBox>

            <VBox spacing="6" maxWidth="Infinity">
                <Label text="Mật khẩu (ít nhất 6 ký tự)" styleClass="field-label"/>
                <PasswordField fx:id="txtRegPassword"
                               promptText="Nhập mật khẩu..."
                               styleClass="login-field"/>
            </VBox>

            <Label fx:id="lblRegStatus" text="" wrapText="true"
                   maxWidth="340" styleClass="status-error"/>

            <StackPane>
                <Button fx:id="btnRegister" text="ĐĂNG KÝ"
                        onAction="#handleRegister"
                        styleClass="btn-primary" maxWidth="Infinity"/>
                <ProgressIndicator fx:id="spinnerReg" maxWidth="28" maxHeight="28"
                                   StackPane.alignment="CENTER_RIGHT"
                                   style="-fx-progress-color: white;"/>
            </StackPane>

            <!-- Switch back to login -->
            <HBox alignment="CENTER" spacing="6">
                <Label text="Đã có tài khoản?" styleClass="login-hint"/>
                <Hyperlink fx:id="lnkGoLogin" text="Đăng nhập"
                           onAction="#showLoginCard"
                           styleClass="login-link"/>
            </HBox>

        </VBox>

        <!-- Footer -->
        <Label fx:id="lblVersion" text="" styleClass="login-footer"
               VBox.vgrow="ALWAYS"/>

    </VBox>
</StackPane>
